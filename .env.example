# ============================================================================
# KARINA AI — КОНФИГУРАЦИЯ (.env)
# ============================================================================
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# TELEGRAM (обязательно)
# Получить на https://my.telegram.org/apps
# ----------------------------------------------------------------------------
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890
KARINA_BOT_TOKEN=123456:ABCDEF-1234567890abcdef1234567890AB
MY_TELEGRAM_ID=123456789

# SESSION_STRING — для userbot (ауры, emoji-статусы)
# Получить командой: python scripts/get_session.py
# Или оставить пустым если ауры не нужны
SESSION_STRING=

# ----------------------------------------------------------------------------
# MISTRAL AI (обязательно)
# Получить на https://console.mistral.ai/api-keys
# ----------------------------------------------------------------------------
MISTRAL_API_KEY=your_mistral_api_key_here

# ----------------------------------------------------------------------------
# SUPABASE (обязательно)
# Получить на https://supabase.com
# Settings → API → Project URL и service_role key
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here_very_long_string

# ----------------------------------------------------------------------------
# GOOGLE CALENDAR (опционально)
# Получить: Google Cloud Console → Credentials → Service Account JSON
# Вставьте содержимое JSON файла (без пробелов)
# ----------------------------------------------------------------------------
GOOGLE_CALENDAR_CREDENTIALS=

# ----------------------------------------------------------------------------
# WEATHER API (опционально)
# Получить на https://openweathermap.org/api
# ----------------------------------------------------------------------------
WEATHER_API_KEY=your_openweather_api_key
WEATHER_CITY=Moscow

# ----------------------------------------------------------------------------
# MARZBAN VPN API (опционально — для VPN магазина)
# URL вашей панели Marzban
# ----------------------------------------------------------------------------
MARZBAN_URL=http://localhost:8000
MARZBAN_USER=admin
MARZBAN_PASS=your_marzban_password

# ----------------------------------------------------------------------------
# HUGGING FACE (опционально — для STT/транскрибации)
# Получить на https://huggingface.co/settings/tokens
# ----------------------------------------------------------------------------
HF_TOKEN=your_huggingface_token

# ----------------------------------------------------------------------------
# API SECRET (опционально — для Mini App)
# Любая случайная строка для подписи JWT
# ----------------------------------------------------------------------------
KARINA_API_SECRET=your_random_secret_key_here

# ----------------------------------------------------------------------------
# TARGET USER ID (опционально — для ограничения доступа)
# Telegram ID пользователя которому разрешён доступ
# 0 — разрешить всем
# ----------------------------------------------------------------------------
TARGET_USER_ID=0
